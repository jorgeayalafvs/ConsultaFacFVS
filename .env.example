# ===========================================================
# Configuracion de la API intermedia - Consulta de Facturas
# ===========================================================
# Copiar este archivo como ".env" y completar con tus datos reales.
# NUNCA subir el archivo ".env" real a Github ni compartirlo.

# --- Conexion a la base de datos de Open Orange (MySQL local) ---
# Si usas Cloudflare Tunnel en modo "private network" estos datos
# son los mismos que usarias conectandote desde la PC local.
OO_DB_HOST=127.0.0.1
OO_DB_PORT=3306
OO_DB_USER=usuario_solo_lectura
OO_DB_PASSWORD=clave_super_secreta
OO_DB_NAME=nombre_base_openorange

# --- Seguridad de la propia API ---
# Generar un valor largo y aleatorio, por ejemplo con:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambiar_esto_por_un_valor_aleatorio_largo

# Clave para habilitar cedulas por API administrativa.
# Usar un valor largo y secreto. No compartir con clientes.
ADMIN_SECRET=cambiar_esto_por_otro_valor_aleatorio_largo

# Tiempo de expiracion del token de sesion
JWT_EXPIRES_IN=8h

# --- Puerto donde corre la API ---
PORT=3000

# --- CORS: dominio del frontend autorizado (separados por coma) ---
ALLOWED_ORIGINS=http://localhost:3000,https://tu-frontend.vercel.app

# --- Diagnostico opcional ---
# Poner 1 solo mientras estas probando para ver detalles de errores SQL.
SHOW_SQL_ERRORS=0
